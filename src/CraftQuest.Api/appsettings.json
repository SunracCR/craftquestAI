{
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "CraftQuest",
    "Audience": "CraftQuest.App",
    "SecretKey": "CraftQuest-Development-Secret-Key-Min-32-Chars!",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Ai": {
    "Enabled": true,
    "UseGemini": true,
    "GeminiApiKey": "",
    "GeminiModel": "gemini-2.5-flash",
    "GeminiFallbackModels": [ "gemini-2.5-flash-lite" ],
    "CreditsPerNormalize": 1,
    "CreditsPerQuizGenerationBase": 2,
    "CreditsPerQuizGenerationPer10Questions": 1,
    "QuizGenerationPromptVersion": "quiz-gen-v1-2026-05"
  },
  "AiGeneration": {
    "MaxUploadBytes": 26214400,
    "MaxPagesPerMaterial": 120,
    "MaxPagesPerGeneration": 30,
    "MaxWordsPerGeneration": 12000,
    "MaxQuestionsPerGeneration": 40,
    "RetentionDays": 3,
    "GenerationJobMaxAttempts": 4,
    "DeferredRetryMaxAttempts": 3,
    "DeferredRetryDelayMinutes": [ 2, 5, 15 ],
    "StaleProcessingMinutes": 12,
    "StaleProcessingMinutesOnStart": 8,
    "GenerationJobTimeoutMinutes": 15,
    "EnableAiGenerationTraceLogging": true,
    "TraceLogDirectory": "logs/ai-gen-trace",
    "TraceMaxLoggedCharacters": 12000,
    "ChunkTargetWordsPerRequest": 3800,
    "MaxParallelChunkRequests": 3,
    "UseOutlinePhase": true,
    "OutlineMaxSourceCharacters": 10000,
    "MinQuestionsForOutlinePhase": 5,
    "OutlineGeminiModel": "gemini-2.5-flash-lite",
    "DeduplicateMergedQuestions": true
  },
  "Media": {
    "StorageProvider": "local",
    "LocalRootPath": "App_Data/media",
    "PublicBasePath": "/api/media",
    "MaxUploadBytes": 5242880,
    "Azure": {
      "ConnectionString": "",
      "ContainerName": "craftquest-media"
    }
  },
  "Payments": {
    "UseMockPayments": true,
    "CurrencyCode": "USD",
    "PayPal": {
      "ClientId": "",
      "ClientSecret": "",
      "ApiBaseUrl": "https://api-m.sandbox.paypal.com",
      "ReturnUrl": "https://localhost:7080/billing/paypal/return",
      "CancelUrl": "https://localhost:7080/billing/paypal/cancel"
    },
    "Mobile": {
      "GooglePlayPackageName": "com.craftquest.app",
      "AppleSharedSecret": ""
    },
    "PlanProducts": {
      "pro": {
        "PayPalPlanCode": "pro",
        "GooglePlayProductId": "craftquest_pro_monthly",
        "AppStoreProductId": "craftquest_pro_monthly"
      },
      "teacher": {
        "PayPalPlanCode": "teacher",
        "GooglePlayProductId": "craftquest_teacher_monthly",
        "AppStoreProductId": "craftquest_teacher_monthly"
      }
    }
  }
}

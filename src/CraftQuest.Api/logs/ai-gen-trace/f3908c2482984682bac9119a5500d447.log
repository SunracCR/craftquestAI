  "cqifVersion": "2.0",
  "quiz": {
    "title": "Empirical Strategies and Measurement in Software Engineering",
    "language": "en",
    "pedagogicalGoal": "assessment",
    "topicFocus": "Prueba en Inglés"
  },
  "questions": [
    {
      "externalId": "q-15",
      "type": "multiple_choice",
      "difficulty": "medium",
      "text": "What should be considered regarding confidentiality procedures in empirical studies?",
      "answerOptions": [
        {
          "key": "a",
          "text": "Data privacy, data anonymity, and anonymity of participation are key aspects."
        },
        {
          "key": "b",
          "text": "Confidentiality measures must be taken even if they conflict with publication interests."
        },
        {
          "key": "c",
          "text": "For small subject numbers, there's a risk of tracing information to individuals despite anonymization."
        },
        {
          "key": "d",
          "text": "Reporting study context for external validity may conflict with anonymity."
        },
        {
          "key": "e",
          "text": "Anonymity of participation is easily achieved in most settings."
        }
      ],
      "correctAnswerKeys": [
        "a",
        "b",
        "c",
        "d"
      ]
    },
    {
      "externalId": "q-16",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What should sponsors include in informed consent forms regarding publication rights?",
      "answerOptions": [
        {
          "key": "a",
          "text": "Clear statements on rights for independent publications of anonymized results."
        },
        {
          "key": "b",
          "text": "A guarantee that all results will be published immediately."
        },
        {
          "key": "c",
          "text": "A clause allowing sponsors to veto any publication."
        },
        {
          "key": "d",
          "text": "Details about the researchers' personal publication history."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-17",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What is a recommended action for researchers regarding statistical analyses of anonymized data?",
      "answerOptions": [
        {
          "key": "a",
          "text": "Have peers perform statistical analyses on anonymized data independently from the experimenters."
        },
        {
          "key": "b",
          "text": "Conduct all statistical analyses themselves to maintain full control."
        },
        {
          "key": "c",
          "text": "Share raw, non-anonymized data with peers for analysis."
        },
        {
          "key": "d",
          "text": "Only perform statistical analyses if the hypotheses are supported."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-18",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What is the purpose of addressing ethical dilemmas in empirical studies?",
      "answerOptions": [
        {
          "key": "a",
          "text": "To reduce the risk of ethical dilemmas and increase study validity."
        },
        {
          "key": "b",
          "text": "To ensure all participants agree with the study's conclusions."
        },
        {
          "key": "c",
          "text": "To speed up the publication process of research findings."
        },
        {
          "key": "d",
          "text": "To minimize the financial cost of conducting the study."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-19",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What is considered sufficient inducement for participants in some software engineering experiments?",
      "answerOptions": [
        {
          "key": "a",
          "text": "The experience and knowledge gained by applying a new method."
        },
        {
          "key": "b",
          "text": "A substantial monetary payment."
        },
        {
          "key": "c",
          "text": "Guaranteed co-authorship on any resulting publications."
        },
        {
          "key": "d",
          "text": "A formal certificate of participation."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-20",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What must be balanced when offering monetary or other inducements for participation?",
      "answerOptions": [
        {
          "key": "a",
          "text": "Ensuring voluntary consent, not forced by excessive inducements."
        },
        {
          "key": "b",
          "text": "The total budget allocated for participant compensation."
        },
        {
          "key": "c",
          "text": "The number of participants versus the amount of inducement."
        },
        {
          "key": "d",
          "text": "The type of inducement with the study's scientific value."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-21",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "Why is feedback of results and analysis important for maintaining long-term relationships with study subjects?",
      "answerOptions": [
        {
          "key": "a",
          "text": "To maintain long-term relationships and trust with the subjects."
        },
        {
          "key": "b",
          "text": "To allow subjects to correct any errors in the analysis."
        },
        {
          "key": "c",
          "text": "To fulfill a legal requirement for all empirical studies."
        },
        {
          "key": "d",
          "text": "To encourage subjects to participate in future studies without further inducement."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-22",
      "type": "single_choice",
      "difficulty": "medium",
      "text": "What is the status of a formal code of ethics specifically for empirical software engineering?",
      "answerOptions": [
        {
          "key": "a",
          "text": "The community has not yet developed a formal code of ethics specifically for empirical software engineering."
        },
        {
          "key": "b",
          "text": "A comprehensive formal code of ethics was developed 10 years ago."
        },
        {
          "key": "c",
          "text": "General codes of ethics are perfectly tailored for empirical software engineering."
        },
        {
          "key": "d",
          "text": "Vinson and Singer's guidelines are a formal code of ethics."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-23",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What is the fundamental reason why software measurement is crucial for projects, products, and processes?",
      "answerOptions": [
        {
          "key": "a",
          "text": "To enable control of projects, products, and processes."
        },
        {
          "key": "b",
          "text": "To reduce the overall cost of software development."
        },
        {
          "key": "c",
          "text": "To automate all aspects of software quality assurance."
        },
        {
          "key": "d",
          "text": "To eliminate the need for human judgment in software engineering."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-24",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "Why is measurement essential for conducting an empirical study?",
      "answerOptions": [
        {
          "key": "a",
          "text": "It enables control of the study and allows researchers to see the effects of inputs on outputs."
        },
        {
          "key": "b",
          "text": "It simplifies the process of recruiting participants for the study."
        },
        {
          "key": "c",
          "text": "It guarantees that the study results will be statistically significant."
        },
        {
          "key": "d",
          "text": "It is primarily used to reduce the time required for data collection."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-25",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "According to the definition provided, what is 'measurement'?",
      "answerOptions": [
        {
          "key": "a",
          "text": "The process of assigning numbers or symbols to attributes of entities according to clearly defined rules."
        },
        {
          "key": "b",
          "text": "The act of making judgments directly on real entities."
        },
        {
          "key": "c",
          "text": "The collection of qualitative data without numerical assignment."
        },
        {
          "key": "d",
          "text": "The subjective evaluation of software quality by experts."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-26",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What is a 'measure' as defined in the text?",
      "answerOptions": [
        {
          "key": "a",
          "text": "The number or symbol assigned to an entity to characterize an attribute."
        },
        {
          "key": "b",
          "text": "The entire process of assigning numbers or symbols."
        },
        {
          "key": "c",
          "text": "A qualitative description of an entity."
        },
        {
          "key": "d",
          "text": "A statistical analysis technique."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    },
    {
      "externalId": "q-27",
      "type": "multiple_choice",
      "difficulty": "medium",
      "text": "How is the term 'software metrics' used in software engineering?",
      "answerOptions": [
        {
          "key": "a",
          "text": "To denote the field of measurement in software engineering."
        },
        {
          "key": "b",
          "text": "To denote an entity which is measured."
        },
        {
          "key": "c",
          "text": "To refer exclusively to the size of a program."
        },
        {
          "key": "d",
          "text": "To describe the process of assigning numbers to attributes."
        }
      ],
      "correctAnswerKeys": [
        "a",
        "b"
      ]
    },
    {
      "externalId": "q-28",
      "type": "single_choice",
      "difficulty": "easy",
      "text": "What is an example of a product metric mentioned in the text?",
      "answerOptions": [
        {
          "key": "a",
          "text": "Lines of Code (LOC)."
        },
        {
          "key": "b",
          "text": "Number of defects found per hour."
        },
        {
          "key": "c",
          "text": "Team velocity."
        },
        {
          "key": "d",
          "text": "Customer satisfaction score."
        }
      ],
      "correctAnswerKeys": [
        "a"
      ]
    }
  ]
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "CraftQuest.Infrastructure.Services.Ai.AiGenerationTraceContext": "None"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Warning"
      }
    }
  },
  "ApplicationInsights": {
    "TracesPerSecond": 5,
    "EnableQuickPulseMetricStream": false
  },
  "AiGeneration": {
    "EnableAiGenerationTraceLogging": false
  }
}
